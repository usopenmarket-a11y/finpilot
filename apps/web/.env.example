# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical site URL — used by the auth callback route to build safe redirect
# URLs without trusting the inbound request's Host/X-Forwarded-Host headers.
# Set this to your production Vercel URL in production (e.g. https://finpilot.vercel.app).
# Leave unset in local development; the callback will fall back to localhost.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
